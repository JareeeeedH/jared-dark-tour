---
import { BRAND_NAME, LINE_URL, SERVICE_EMAIL, TELEGRAM_URL } from '../data/site';
import WeChatLink from './WeChatLink.astro';

interface Props {
	variant?: 'home' | 'default';
	/** e.g. 「胡志明市專頁」 */
	suffix?: string;
}

const { variant = 'default', suffix } = Astro.props;
const year = new Date().getFullYear();
const footerClass =
	variant === 'home'
		? 'scroll-reveal relative z-10 mt-20 flex w-full flex-col items-center space-y-4 border-t border-border/80 py-8 text-center text-xs text-dim'
		: 'relative z-10 flex w-full flex-col items-center gap-2 border-t border-border/80 bg-page/50 py-6 text-center text-xs text-dim';
const linkClass = 'underline transition hover:text-body';
---

<footer class={footerClass}>
	{
		variant === 'home' && (
			<>
				<div class="flex flex-wrap items-center justify-center gap-6">
					<a
						href={LINE_URL}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={`LINE 官方 ${BRAND_NAME}`}
						class="text-body transition hover:text-[#06C755]"
					>
						<svg class="h-[30px] w-[30px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.406h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.405h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314" />
						</svg>
					</a>
					<a
						href={TELEGRAM_URL}
						target="_blank"
						rel="noopener noreferrer"
						aria-label={`Telegram ${BRAND_NAME}`}
						class="text-body transition hover:text-[#229ED9]"
					>
						<svg class="h-[30px] w-[30px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.831-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
						</svg>
					</a>
					<WeChatLink />
				</div>
				<p class="max-w-xl px-4 leading-relaxed">
					我們對接在地強大資源，並且我們嚴格遵守不放任何客戶隱私照片與個人介紹的最高安全規範，全力保護所有客人的行蹤隱私與安全。
				</p>
			</>
		)
	}
	<p>
		聯絡 Email：
		<a href={`mailto:${SERVICE_EMAIL}`} class={linkClass}>{SERVICE_EMAIL}</a>
	</p>
	<p>
		<a href="/privacy" class={linkClass}>隱私權政策</a>
		<span class="mx-2">·</span>
		© {year} {BRAND_NAME}{suffix ? ` · ${suffix}` : ''}
	</p>
</footer>
