---
---

<div class="mb-8 w-full border-b border-[#222C3F]">
	<div
		id="sub-nav-intro"
		class="flex w-full justify-start gap-6 md:gap-10"
		role="tablist"
		aria-label="玩法子分頁"
	>
		<button
			type="button"
			data-sub-tab="day"
			class="sub-tab-btn border-b-2 border-[#800020] px-2 pb-3 text-sm font-bold text-[#FFFFFF] transition md:text-base"
			aria-selected="true"
		>
			日光
		</button>
		<button
			type="button"
			data-sub-tab="night"
			class="sub-tab-btn border-b-2 border-transparent px-2 pb-3 text-sm font-medium text-[#888888] transition md:text-base"
			aria-selected="false"
		>
			夜晚
		</button>
	</div>
	<div id="sub-nav-pricing" class="flex w-full justify-start" hidden>
		<span
			class="border-b-2 border-[#800020] px-2 pb-3 text-sm font-bold text-[#FFFFFF] md:text-base"
		>
			費用介紹
		</span>
	</div>
</div>
