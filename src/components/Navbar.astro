---
import { BRAND_NAME, BRAND_NAME_CN, LINE_URL } from '../data/site';

interface Props {
	homeHref?: string;
}

const { homeHref = '/' } = Astro.props;

/** 首頁用 #top，城市頁用 / → 錨點需加前綴 */
const sectionBase = homeHref === '#top' ? '' : '/';

const navLinkClass =
	'font-brand-cn block w-full rounded-xl border border-border bg-card/80 px-4 py-3 text-center text-sm font-medium text-body transition hover:border-[#800020]/50 hover:bg-surface/60 hover:text-[#FFFFFF]';

const navLinkClassDesktop =
	'font-brand-cn inline-flex shrink-0 items-center whitespace-nowrap rounded-full border border-border bg-card/50 px-2.5 py-1.5 text-[10px] font-medium text-body transition hover:border-[#800020]/50 hover:bg-surface/60 hover:text-[#FFFFFF] md:px-3.5 md:py-2 md:text-[13px]';
---

<header
	class="sticky top-0 z-50 w-full border-b border-border bg-page/90 backdrop-blur-md"
>
	<div class="mx-auto flex w-full max-w-5xl items-center justify-between gap-3 px-4 py-3 sm:px-6 md:py-4">
		<a
			href={homeHref}
			class="group flex min-w-0 flex-1 items-center gap-2"
			aria-label={`${BRAND_NAME} 回首頁`}
		>
			<img
				src="/images/logo.png"
				onerror="this.onerror=null;this.src='/images/logo.svg';"
				alt={`${BRAND_NAME} Logo`}
				width="28"
				height="28"
				loading="lazy"
				class="h-7 w-7 shrink-0 object-contain"
			/>
			<span class="font-brand-cn truncate text-[15px] font-semibold tracking-wide sm:text-base">
				{BRAND_NAME_CN}
			</span>
		</a>

		<button
			type="button"
			id="nav-menu-toggle"
			class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-border bg-card/80 text-body transition hover:border-[#800020]/50 hover:text-[#FFFFFF] md:hidden"
			aria-expanded="false"
			aria-controls="nav-mobile-panel"
			aria-label="開啟選單"
		>
			<svg
				id="nav-icon-open"
				class="h-5 w-5"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				aria-hidden="true"
			>
				<path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
			</svg>
			<svg
				id="nav-icon-close"
				class="hidden h-5 w-5"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				aria-hidden="true"
			>
				<path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"></path>
			</svg>
		</button>

		<nav class="hidden items-center gap-1.5 md:flex md:gap-2" aria-label="主要導覽">
			<a href={`${sectionBase}#city-section`} class={navLinkClassDesktop}> 選擇旅程 </a>
			<a href={`${sectionBase}#faq-section`} class={navLinkClassDesktop}> 常見問題 </a>
			<a href={`${sectionBase}#blog-section`} class={navLinkClassDesktop}> 深夜讀物 </a>
			<a
				href={LINE_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="font-brand-cn animate-pulse shrink-0 rounded-full bg-[#800020] px-3.5 py-2 text-xs font-semibold text-[#FFFFFF] transition hover:bg-[#990026] md:px-4"
			>
				立即聯繫
			</a>
		</nav>
	</div>

	<nav
		id="nav-mobile-panel"
		class="nav-mobile-panel border-t border-border md:hidden"
		aria-label="手機導覽"
		aria-hidden="true"
		hidden
	>
		<div class="nav-mobile-panel__inner bg-page/98 px-4 py-4">
			<ul class="flex flex-col gap-2">
				<li>
					<a href={`${sectionBase}#city-section`} class={navLinkClass} data-nav-close> 選擇旅程 </a>
				</li>
				<li>
					<a href={`${sectionBase}#faq-section`} class={navLinkClass} data-nav-close> 常見問題 </a>
				</li>
				<li>
					<a href={`${sectionBase}#blog-section`} class={navLinkClass} data-nav-close> 深夜讀物 </a>
				</li>
				<li class="pt-1">
					<a
						href={LINE_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="font-brand-cn block w-full rounded-xl bg-[#800020] px-4 py-3 text-center text-sm font-semibold text-[#FFFFFF] transition hover:bg-[#990026]"
					>
						立即聯繫 LINE
					</a>
				</li>
			</ul>
		</div>
	</nav>
</header>

<style>
	.nav-mobile-panel {
		display: block;
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
		transition:
			max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
			opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.nav-mobile-panel.is-open {
		max-height: 18rem;
		opacity: 1;
		pointer-events: auto;
	}

	.nav-mobile-panel__inner {
		transform: translateY(-4px);
		transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.nav-mobile-panel.is-open .nav-mobile-panel__inner {
		transform: translateY(0);
	}

	#nav-menu-toggle .nav-toggle-icon {
		transition: opacity 0.2s ease;
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-mobile-panel,
		.nav-mobile-panel__inner {
			transition: none;
		}
	}
</style>

<script is:inline>
	(() => {
		const toggle = document.getElementById('nav-menu-toggle');
		const panel = document.getElementById('nav-mobile-panel');
		const iconOpen = document.getElementById('nav-icon-open');
		const iconClose = document.getElementById('nav-icon-close');
		if (!toggle || !panel) return;

		let isClosing = false;

		const syncToggleUi = (open) => {
			toggle.setAttribute('aria-expanded', String(open));
			toggle.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
			iconOpen?.classList.toggle('hidden', open);
			iconClose?.classList.toggle('hidden', !open);
		};

		const lockScroll = (lock) => {
			document.body.classList.toggle('overflow-hidden', lock);
		};

		const finishClose = () => {
			panel.hidden = true;
			panel.setAttribute('aria-hidden', 'true');
			isClosing = false;
		};

		const setOpen = (open) => {
			if (isClosing && open) return;

			if (open) {
				isClosing = false;
				panel.hidden = false;
				panel.setAttribute('aria-hidden', 'false');
				syncToggleUi(true);
				lockScroll(true);
				requestAnimationFrame(() => {
					panel.classList.add('is-open');
				});
				return;
			}

			if (!panel.classList.contains('is-open')) return;

			isClosing = true;
			panel.classList.remove('is-open');

			const onEnd = (event) => {
				if (event.target !== panel || event.propertyName !== 'max-height') return;
				panel.removeEventListener('transitionend', onEnd);
				syncToggleUi(false);
				lockScroll(false);
				finishClose();
			};

			panel.addEventListener('transitionend', onEnd);
			window.setTimeout(() => {
				if (!isClosing) return;
				panel.removeEventListener('transitionend', onEnd);
				syncToggleUi(false);
				lockScroll(false);
				finishClose();
			}, 450);
		};

		toggle.addEventListener('click', () => {
			setOpen(toggle.getAttribute('aria-expanded') !== 'true');
		});

		panel.querySelectorAll('[data-nav-close]').forEach((link) => {
			link.addEventListener('click', () => setOpen(false));
		});

		window.addEventListener('resize', () => {
			if (window.matchMedia('(min-width: 768px)').matches) {
				panel.classList.remove('is-open');
				syncToggleUi(false);
				lockScroll(false);
				finishClose();
			}
		});
	})();
</script>
