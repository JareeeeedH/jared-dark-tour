---
---

<div
	class="mb-6 flex w-full flex-wrap justify-start gap-2"
	role="tablist"
	aria-label="主選單"
>
	<button
		type="button"
		data-main-tab="intro"
		class="main-tab-btn inline-flex items-center gap-2 rounded-lg bg-[#800020] px-4 py-2 text-xs font-bold text-[#FFFFFF] transition md:px-5 md:py-2.5 md:text-sm"
		aria-selected="true"
	>
		<svg
			class="h-4 w-4 shrink-0 md:h-5 md:w-5"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.75"
			aria-hidden="true"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				d="M12 3 4 9v12h16V9l-8-6z"
			></path>
			<path stroke-linecap="round" stroke-linejoin="round" d="M9 21V12h6v9"></path>
			<path stroke-linecap="round" d="M8 12h8"></path>
		</svg>
		<span>景點</span>
	</button>
	<button
		type="button"
		data-main-tab="pricing"
		class="main-tab-btn inline-flex items-center gap-2 rounded-lg bg-card px-4 py-2 text-xs font-bold text-body transition md:px-5 md:py-2.5 md:text-sm"
		aria-selected="false"
	>
		<svg
			class="h-4 w-4 shrink-0 md:h-5 md:w-5"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.75"
			aria-hidden="true"
		>
			<rect x="2" y="6" width="20" height="12" rx="2"></rect>
			<circle cx="12" cy="12" r="2.5"></circle>
			<path stroke-linecap="round" d="M6 10h.01M18 10h.01M6 14h.01M18 14h.01"></path>
		</svg>
		<span>參團</span>
	</button>
</div>
