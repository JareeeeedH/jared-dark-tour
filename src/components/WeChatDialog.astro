---
import { WECHAT_ID, WECHAT_QR_SRC } from '../data/site';
---

<dialog
	id="wechat-dialog"
	class="wechat-dialog fixed inset-0 z-[100] m-0 max-h-none max-w-none border-0 bg-transparent p-4 backdrop:bg-black/70"
	aria-labelledby="wechat-dialog-title"
	data-wechat-id={WECHAT_ID}
	data-wechat-qr={WECHAT_QR_SRC}
>
	<div
		class="mx-auto mt-[10vh] w-full max-w-sm rounded-2xl border border-border bg-card p-6 text-center shadow-2xl"
	>
		<h2 id="wechat-dialog-title" class="text-lg font-bold text-[#FFFFFF]">微信聯繫</h2>
		<p class="mt-2 text-sm text-muted">掃描 QR Code 或複製微信号加入好友</p>
		<img
			id="wechat-dialog-qr"
			src={WECHAT_QR_SRC}
			alt="微信加好友 QR Code"
			width="220"
			height="220"
			class="mx-auto mt-4 hidden rounded-lg border border-border bg-white p-2"
		/>
		<p id="wechat-dialog-id" class="mt-4 hidden text-base font-semibold text-[#07C160]"></p>
		<div class="mt-5 flex flex-col gap-2 sm:flex-row sm:justify-center">
			<button
				type="button"
				id="wechat-copy-btn"
				class="hidden rounded-lg bg-[#07C160] px-4 py-2.5 text-sm font-semibold text-[#FFFFFF] transition hover:bg-[#06ad56]"
			>
				複製微信号
			</button>
			<button
				type="button"
				id="wechat-dialog-close"
				class="rounded-lg border border-border px-4 py-2.5 text-sm text-body transition hover:border-muted hover:text-[#FFFFFF]"
			>
				關閉
			</button>
		</div>
	</div>
</dialog>

<script is:inline>
	(() => {
		const dialog = document.getElementById('wechat-dialog');
		const qrImg = document.getElementById('wechat-dialog-qr');
		const idEl = document.getElementById('wechat-dialog-id');
		const copyBtn = document.getElementById('wechat-copy-btn');
		const closeBtn = document.getElementById('wechat-dialog-close');
		if (!dialog || !qrImg || !idEl || !copyBtn || !closeBtn) return;

		const defaultId = dialog.getAttribute('data-wechat-id') || '';
		const defaultQr = dialog.getAttribute('data-wechat-qr') || '';
		let currentId = '';

		const openDialog = () => {
			currentId = defaultId;
			qrImg.classList.add('hidden');
			idEl.classList.add('hidden');
			copyBtn.classList.add('hidden');

			if (defaultQr) {
				qrImg.src = defaultQr;
				qrImg.onload = () => qrImg.classList.remove('hidden');
				qrImg.onerror = () => qrImg.classList.add('hidden');
			}

			if (currentId) {
				idEl.textContent = `微信号：${currentId}`;
				idEl.classList.remove('hidden');
				copyBtn.classList.remove('hidden');
			} else if (!defaultQr) {
				idEl.textContent = '尚未設定微信，請先聯繫 LINE 官方';
				idEl.classList.remove('hidden');
			}

			dialog.showModal();
		};

		document.querySelectorAll('.wechat-link').forEach((btn) => {
			btn.addEventListener('click', openDialog);
		});

		closeBtn.addEventListener('click', () => dialog.close());
		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) dialog.close();
		});

		copyBtn.addEventListener('click', async () => {
			if (!currentId) return;
			try {
				await navigator.clipboard.writeText(currentId);
				copyBtn.textContent = '已複製';
				setTimeout(() => {
					copyBtn.textContent = '複製微信号';
				}, 2000);
			} catch {
				window.prompt('請手動複製微信号', currentId);
			}
		});
	})();
</script>
