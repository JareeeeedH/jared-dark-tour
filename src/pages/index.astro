					<div
						class="mt-2 h-[2px] w-16 bg-gradient-to-r from-[#800020] via-[#800020]/35 to-transparent md:mt-2.5"
						aria-hidden="true"
					>
					</div>
				</div>
				<div
					class="scroll-stagger mt-5 grid w-full grid-cols-1 gap-6 md:mt-6 md:grid-cols-2 md:gap-8"
				>
					<a
						href="/ho-chi-minh"
						class="home-city-card scroll-reveal group flex flex-col items-center overflow-hidden rounded-2xl border border-border bg-card/90 p-4 shadow-[0_0_16px_rgba(128,0,32,0.2)] hover:border-[#800020] hover:shadow-[0_0_30px_rgba(128,0,32,0.4)] active:border-[#800020] active:shadow-[0_0_30px_rgba(128,0,32,0.4)]"
					>
						<div
							class="home-city-card__media relative w-full overflow-hidden rounded-xl"
						>
							<img
								src="/hcmGirl.png"
								alt="胡志明市 ｜ Saigon"
								width="800"
								height="480"
								loading="lazy"
								class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.04]"
							/>
							<span
								class="absolute inset-x-0 bottom-0 z-10 px-3 pb-4 pt-12 text-center text-xl font-bold text-[#FFFFFF] drop-shadow-md md:text-2xl"
							>
								胡志明市 ｜ Saigon
							</span>
						</div>
					</a>
					<a
						href="/da-nang"
						class="home-city-card scroll-reveal group flex flex-col items-center overflow-hidden rounded-2xl border border-border bg-card/90 p-4 shadow-[0_0_16px_rgba(128,0,32,0.2)] hover:border-[#800020] hover:shadow-[0_0_30px_rgba(128,0,32,0.4)] active:border-[#800020] active:shadow-[0_0_30px_rgba(128,0,32,0.4)]"
					>
