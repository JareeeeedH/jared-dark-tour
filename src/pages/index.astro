							class="home-city-card__media relative w-full overflow-hidden rounded-xl"
						>
							<img
								src="/haGirl.png"
								alt="峴港市 ｜ Da Nang"
								width="800"
								height="480"
								loading="lazy"
								class="absolute inset-0 h-full w-full object-cover object-center transition duration-500 group-hover:scale-[1.04]"
							/>
							<span
								class="absolute inset-x-0 bottom-0 z-10 px-3 pb-4 pt-12 text-center text-xl font-bold text-[#FFFFFF] drop-shadow-md md:text-2xl"
							>
								峴港市 ｜ Da Nang
							</span>
						</div>
					</a>
				</div>
				<a
					href={LINE_URL}
					target="_blank"
					rel="noopener noreferrer"
					class="scroll-reveal mt-6 self-center rounded-full bg-gradient-to-r from-[#800020] to-[#5A0016] px-6 py-2 text-sm font-semibold text-[#FFFFFF] transition hover:opacity-90"
