								<p class="text-sm leading-relaxed text-muted">
									{processSteps[0].desc}
								</p>
							</div>
							<div class="home-process-step scroll-reveal flex flex-col items-start px-6 py-8 text-left md:px-8">
								<svg
									class="mb-4 h-6 w-6 text-[#800020]"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="1.5"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
